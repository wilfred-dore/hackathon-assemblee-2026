# Copie ce fichier en .env et remplis les valeurs. NE COMMITE JAMAIS .env.
# Toutes les clés sont VIDES par défaut : sans elles, le pipeline tourne en mock.

# Mode : "demo" (hors-ligne, déterministe) ou "live" (MAX/MCP réels). Défaut demo.
MODE=demo

# --- LLM (endpoint OpenAI-compatible, backend swappable) ---
# Le pipeline est agnostique : n'importe quel endpoint OpenAI-compatible marche.
# Backends souverains prêts à l'emploi (remplis-en UN) :
#   Mistral La Plateforme 🇫🇷 : https://api.mistral.ai/v1        | <clé> | mistral-small-latest
#   Scaleway 🇫🇷 (open-weight) : https://api.scaleway.ai/v1       | <clé> | mistral-small-3.2-24b-instruct-2506
#   Qualcomm Cloud AI 100 (Cirrascale) : https://aisuite.cirrascale.com/apis/v2 | <clé> | Llama-3.1-8B
#   MAX auto-hébergé (Thunder/RunPod/Modal) : http://<host>:8000/v1 | sk-noauth | mistralai/Mistral-7B-Instruct-v0.3
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# --- MCP ---
MCP_MOULINEUSE_URL=https://mcp.hackathon2026.leximpact.dev/mcp
MCP_PARLEMENT_URL=
MCP_TOKEN=

# --- Canutes (PostgREST + accès DB direct optionnel) ---
CANUTES_REST_URL=https://db.code4code.eu/canutes/
CANUTES_DB_HOST=hackathon2026.leximpact.dev
CANUTES_DB_PORT=5432
CANUTES_DB_USER=hackathon2026
CANUTES_DB_PASSWORD=
